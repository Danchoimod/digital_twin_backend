# MQTT Configuration
MQTT_BROKER=broker.emqx.io
MQTT_PORT=1883
MQTT_TOPIC=iot/data/phupham
MQTT_KEEP_ALIVE=60

# Device Simulator Configuration
DEVICE_ID=DEVICE_PHU_PHAM_001
DEVICE_TOKEN=secret_token_123
SEND_INTERVAL_SECONDS=5

# Google Cloud Platform Configuration
GCP_PROJECT_ID=your-gcp-project-id
GCP_PUBSUB_TOPIC=your-pubsub-topic-id
# Path to your Service Account JSON credentials (absolute path or relative to project root)
GCP_CREDENTIALS_PATH=../credentials.json

# Valid Devices List (JSON format mapping device ID to authorized token)
# Used by the Bridge to authenticate incoming device connections
VALID_DEVICES='{"DEVICE_PHU_PHAM_001": "secret_token_123", "DEVICE_TEST_002": "token_abc_456"}'

# Backend API verification URL
BACKEND_VERIFY_URL=http://localhost:8000/api/v1/devices/verify

